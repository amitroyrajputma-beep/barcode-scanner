<!DOCTYPE html>
<html>
<head>
    <title>Box Barcode Scanner</title>

    <script src="https://unpkg.com/html5-qrcode"></script>

    <style>
        body{
            font-family:Arial;
            text-align:center;
            padding:20px;
        }

        #reader{
            width:350px;
            margin:auto;
        }

        #result{
            margin-top:20px;
            font-size:24px;
            font-weight:bold;
        }

        .found{
            color:green;
        }

        .notfound{
            color:red;
        }
    </style>
</head>
<body>

<h2>Box Scanner</h2>

<div id="reader"></div>

<div id="result">Scan a barcode...</div>

<script>

const boxList = [
    "PBA9294014508S",
    "PD31262424545S",
    "PH45358511412S"
];

function onScanSuccess(decodedText) {

    if(boxList.includes(decodedText.trim())){

        document.getElementById("result").innerHTML =
            "✅ MATCH FOUND<br>" + decodedText;

        document.getElementById("result").className = "found";

    }else{

        document.getElementById("result").innerHTML =
            "❌ NOT IN LIST<br>" + decodedText;

        document.getElementById("result").className = "notfound";
    }
}

const scanner = new Html5QrcodeScanner(
    "reader",
    {
        fps:10,
        qrbox:250
    }
);

scanner.render(onScanSuccess);

</script>

</body>
</html>
